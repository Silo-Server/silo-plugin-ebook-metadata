{
  "plugin_id": "silo.ebook-metadata",
  "version": "0.1.0",
  "checksum": "__CHECKSUM__",
  "silo_api_version": "v1",
  "supported_platforms": [
    {
      "os": "darwin",
      "arch": "arm64"
    },
    {
      "os": "linux",
      "arch": "amd64"
    },
    {
      "os": "linux",
      "arch": "arm64"
    }
  ],
  "capabilities": [
    {
      "type": "metadata_provider.v1",
      "id": "ebook-metadata",
      "display_name": "Ebook Metadata",
      "description": "Metadata provider for ebook items. Wraps OpenLibrary, Google Books, ISBNdb, Hardcover, Goodreads, Amazon, Anna's Archive, Project Gutenberg, BookBrainz, FantasticFiction, ISFDB, LibraryThing, Internet Archive, WorldCat, and Douban.",
      "metadata": {
        "default_priority": {
          "ebook": 2
        }
      }
    }
  ],
  "global_config_schema": [
    {
      "key": "enabled_sources",
      "title": "Enabled sources",
      "description": "Comma-separated source IDs to search. Empty uses the default source set.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Source IDs",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "google_books_api_key",
      "title": "Google Books API key",
      "description": "Optional API key for Google Books.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "API key",
            "control": "ADMIN_FORM_CONTROL_PASSWORD"
          }
        ]
      }
    },
    {
      "key": "isbndb_api_key",
      "title": "ISBNdb API key",
      "description": "Optional API key for ISBNdb.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "API key",
            "control": "ADMIN_FORM_CONTROL_PASSWORD"
          }
        ]
      }
    },
    {
      "key": "hardcover_api_key",
      "title": "Hardcover API key",
      "description": "Optional API key for Hardcover.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "API key",
            "control": "ADMIN_FORM_CONTROL_PASSWORD"
          }
        ]
      }
    },
    {
      "key": "default_region",
      "title": "Default region",
      "description": "Optional region hint used by sources that support regional catalogs.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Region code",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    }
  ]
}
